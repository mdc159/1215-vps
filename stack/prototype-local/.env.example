# 1215 prototype-local environment
#
# The prototype compose has built-in defaults so it can render without this
# file, but real values here make local testing less ambiguous.
#
# Active usage:
# - postgres: POSTGRES_PASSWORD
# - minio: MINIO_ROOT_PASSWORD
# - clickhouse/langfuse: CLICKHOUSE_PASSWORD
# - langfuse: LANGFUSE_SALT, ENCRYPTION_KEY, NEXTAUTH_SECRET
# - n8n: N8N_ENCRYPTION_KEY, N8N_USER_MANAGEMENT_JWT_SECRET
# - neo4j: NEO4J_AUTH
#
# This file is the committed contract. Generate a local `.env` from it with:
# python3 stack/prototype-local/scripts/init_env.py

# Postgres
POSTGRES_PASSWORD=replace-with-local-postgres-password

# MinIO
MINIO_ROOT_PASSWORD=replace-with-local-minio-password

# ClickHouse / Langfuse
CLICKHOUSE_PASSWORD=replace-with-local-clickhouse-password

# Langfuse
LANGFUSE_SALT=replace-with-local-langfuse-salt
# 32 bytes minimum recommended for Langfuse encryption
ENCRYPTION_KEY=replace-with-32-byte-minimum-langfuse-key
NEXTAUTH_SECRET=replace-with-local-nextauth-secret

# n8n
N8N_BASE_IMAGE=n8nio/n8n:latest
N8N_ENCRYPTION_KEY=replace-with-local-n8n-encryption-key
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-local-n8n-jwt-secret
N8N_API_KEY=replace-with-local-n8n-api-key-if-using-n8n-mcp
# File access remains restricted by default in n8n 2.x. The compose stack widens
# the allowlist to include /data/shared and disables n8n's internal block on
# ~/.n8n-files so Read Binary File can consume locally generated media before
# S3 upload.

# n8n-mcp
N8N_MCP_AUTH_TOKEN=replace-with-local-n8n-mcp-auth-token
N8N_MCP_LOG_LEVEL=info
N8N_MCP_REBUILD_ON_START=false
N8N_MCP_TELEMETRY_DISABLED=true

# ComfyUI
# These are used if the optional `media` profile is enabled.
COMFYUI_IMAGE_TAG=latest
COMFYUI_USER_ID=1000
COMFYUI_GROUP_ID=1000

# Neo4j
# Format: username/password
NEO4J_AUTH=neo4j/replace-with-local-neo4j-password

OPENROUTER_API_KEY=
