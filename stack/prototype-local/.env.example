# Prototype-local defaults are embedded in the compose file so it can render
# without a secret file. Override values here or in your shell if needed.
#
# Examples:
# POSTGRES_PASSWORD=prototype-postgres
# MINIO_ROOT_PASSWORD=prototype-minio-password
# CLICKHOUSE_PASSWORD=prototype-clickhouse-password
# LANGFUSE_SALT=prototype-langfuse-salt
# ENCRYPTION_KEY=prototype-encryption-key-32-bytes-minimum
# NEXTAUTH_SECRET=prototype-nextauth-secret
# N8N_ENCRYPTION_KEY=prototype-n8n-encryption-key
# N8N_USER_MANAGEMENT_JWT_SECRET=prototype-n8n-jwt-secret
