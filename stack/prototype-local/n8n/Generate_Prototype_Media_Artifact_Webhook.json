        "operation": "upload",
        "bucketName": "={{ $('Prepare Artifact').item.json.bucket_name }}",
        "fileName": "={{ $('Prepare Artifact').item.json.file_name }}",
        "binaryData": true,
        "binaryPropertyName": "data",
        "additionalFields": {
          "parentFolderKey": "prototype-media"
        }
      },
      "id": "5e3dfd78-5d5e-4c3f-9ca7-1215aa000315",
