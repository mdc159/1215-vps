      "webhookId": "5e3dfd78-5d5e-4c3f-9ca7-1215aa000311"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const source = ($json.body && Object.keys($json.body).length ? $json.body : $json.query) || {};\nconst uniqueSuffix = `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;\nconst fileName = `prototype-smoke-${uniqueSuffix}.mp4`;\nconst outputDir = '/home/node/.n8n-files/prototype-media';\nconst outputPath = `${outputDir}/${fileName}`;\nreturn [{ json: { prompt: String(source.prompt || 'prototype media smoke').trim(), file_name: fileName, output_dir: outputDir, output_path: outputPath, bucket_name: 'artifacts', folder_key: 'prototype-media', object_key: `prototype-media/${fileName}` } }];"
      },
      "id": "5e3dfd78-5d5e-4c3f-9ca7-1215aa000312",
      "name": "Prepare Artifact",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        280
      ]
    },
    {
      "parameters": {
        "executeOnce": true,
        "command": "={{ `mkdir -p ${$json.output_dir} && ffmpeg -y -f lavfi -i testsrc=size=640x360:rate=24 -f lavfi -i sine=frequency=440:sample_rate=44100 -t 1 -c:v libx264 -pix_fmt yuv420p -c:a aac ${$json.output_path}` }}"
      },
      "id": "5e3dfd78-5d5e-4c3f-9ca7-1215aa000313",
      "name": "Generate Test Video",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        760,
        280
      ]
    },
    {
      "parameters": {
        "filePath": "={{ $('Prepare Artifact').item.json.output_path }}",
        "dataPropertyName": "data"
      },
      "id": "5e3dfd78-5d5e-4c3f-9ca7-1215aa000314",
      "name": "Read Generated Video",
      "type": "n8n-nodes-base.readBinaryFile",
      "typeVersion": 1,
      "position": [
        1020,
        280
      ]
    },
    {
      "parameters": {
