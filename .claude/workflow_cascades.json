{
  "version": "1.0",
  "description": "Workflow-specific model cascade routing. Each workflow defines an ordered fallback chain from most capable to cheapest. Executors cascade down the chain on rate limit errors.",
  "workflows": {
    "coding": {
      "description": "Implementation, feature building, bug fixes, refactoring",
      "keywords": ["implement", "add", "build", "create", "fix bug", "refactor", "feature", "bugfix", "patch"],
      "primary_agent": "hephaestus",
      "fallback_chain": [
        {"model": "opencode/gpt-5.3-codex", "agent": "hephaestus", "tier": "flat_rate"},
        {"model": "opencode/gpt-5.2", "agent": "explore", "tier": "flat_rate"},
        {"model": "openrouter/openai/gpt-5", "agent": null, "tier": "included"},
        {"model": "openrouter/moonshotai/kimi-k2.5", "agent": null, "tier": "cheap"},
        {"model": "groq/moonshotai/kimi-k2-instruct-0905", "agent": "atlas", "tier": "free"}
      ],
      "timeout": 600
    },
    "validation": {
      "description": "Code review, acceptance criteria checking, static analysis",
      "keywords": ["review", "validate", "acceptance criteria", "PASS/FAIL", "archon-task-review", "check", "verify", "lint"],
      "primary_agent": "momus",
      "fallback_chain": [
        {"model": "opencode/gpt-5.2", "agent": "momus", "tier": "flat_rate"},
        {"model": "opencode/gpt-5.3-codex", "agent": null, "tier": "flat_rate"},
        {"model": "openrouter/openai/gpt-5", "agent": "prometheus", "tier": "included"},
        {"model": "google/antigravity-gemini-3-pro-high", "agent": null, "tier": "free"},
        {"model": "openrouter/z-ai/glm-4.5-air:free", "agent": null, "tier": "free"}
      ],
      "timeout": 600
    },
    "research": {
      "description": "Technical research, analysis, evaluation, comparison",
      "keywords": ["research", "analyze", "evaluate", "compare", "investigate", "study", "benchmark", "survey"],
      "primary_agent": "oracle",
      "web_augmentation": [
        {"tool": "perplexity_ask", "cost": 0.01, "use_for": "Quick factual questions"},
        {"tool": "perplexity_search", "cost": 0.005, "use_for": "Finding URLs and snippets"},
        {"tool": "firecrawl_scrape", "cost": 0, "use_for": "Scraping specific URLs"},
        {"tool": "perplexity_research", "cost": 0.40, "use_for": "Exhaustive multi-source research (use sparingly)"}
      ],
      "fallback_chain": [
        {"model": "opencode/gpt-5.2", "agent": "oracle", "tier": "flat_rate"},
        {"model": "groq/gpt-oss-120b", "agent": null, "tier": "free"},
        {"model": "opencode/gpt-5.3-codex", "agent": "metis", "tier": "flat_rate"},
        {"model": "groq/kimi-k2-instruct-0905", "agent": null, "tier": "free"},
        {"model": "google/antigravity-gemini-3-pro-high", "agent": null, "tier": "free"}
      ],
      "timeout": 900
    },
    "documentation": {
      "description": "README generation, API docs, guides, code comments",
      "keywords": ["document", "docs", "README", "API docs", "guide", "changelog", "comments", "diagram"],
      "primary_agent": "atlas",
      "fallback_chain": [
        {"model": "groq/moonshotai/kimi-k2-instruct-0905", "agent": "atlas", "tier": "free"},
        {"model": "opencode/gpt-5-nano", "agent": null, "tier": "included"},
        {"model": "google/antigravity-gemini-3-flash", "agent": null, "tier": "free"},
        {"model": "zai-coding-plan/glm-4.7", "agent": null, "tier": "free"}
      ],
      "timeout": 900
    },
    "security": {
      "description": "Security audit, threat modeling, vulnerability analysis",
      "keywords": ["security", "audit", "vulnerability", "threat model", "OWASP", "CVE", "penetration", "attack surface"],
      "primary_agent": "prometheus",
      "fallback_chain": [
        {"model": "opencode/gpt-5.3-codex", "agent": "prometheus", "tier": "flat_rate"},
        {"model": "opencode/gpt-5.2", "agent": "momus", "tier": "flat_rate"},
        {"model": "google/antigravity-gemini-3-pro-high", "agent": null, "tier": "free"},
        {"model": "openrouter/openai/gpt-5", "agent": null, "tier": "included"}
      ],
      "timeout": 600
    },
    "exploration": {
      "description": "Codebase understanding, pattern discovery, architecture mapping",
      "keywords": ["explore", "understand", "patterns", "architecture", "how does", "codebase", "structure", "discover", "analyze", "scan", "extract"],
      "primary_agent": "explore",
      "fallback_chain": [
        {"model": "opencode/gpt-5.3-codex", "agent": "explore", "tier": "flat_rate"},
        {"model": "opencode/kimi-k2.5", "agent": null, "tier": "included"},
        {"model": "groq/kimi-k2-instruct-0905", "agent": null, "tier": "free"},
        {"model": "groq/gpt-oss-120b", "agent": null, "tier": "free"},
        {"model": "opencode/gpt-5.2", "agent": "oracle", "tier": "flat_rate"},
        {"model": "groq/qwen3-32b", "agent": null, "tier": "free"},
        {"model": "google/antigravity-gemini-3-flash", "agent": null, "tier": "free"}
      ],
      "timeout": 600
    }
  },
  "blocked_models": [
    "opencode/claude-opus-4-6",
    "opencode/claude-opus-4-5",
    "opencode/claude-sonnet-4-5",
    "opencode/claude-sonnet-4",
    "opencode/claude-haiku-4-5",
    "opencode/claude-3-5-haiku"
  ],
  "default_workflow": "coding",
  "retry_config": {
    "intra_tier_max_retries": 1,
    "intra_tier_delay_seconds": 10,
    "cross_tier_delay_seconds": 60,
    "max_total_retries": 5
  }
}
